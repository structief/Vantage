// Migration note: Replace last_browsed with pinned_at on PinnedRepo.
//   Display order is now insertion order (pinned_at ASC), not browse recency.
//   Eviction on add removes the oldest-added (smallest pinned_at) entry.
// Spec reference: specs/feature-repo-sidebar-navigation.md

// -- DELTA ONLY --
// Replaces the previously generated PinnedRepo model. Merge into prisma/schema.prisma.

// Requirement: Sidebar Cap — Insertion Order
model PinnedRepo {
  github_login String
  full_name    String
  pinned_at    DateTime @default(now())

  @@id([github_login, full_name])
  @@index([github_login, pinned_at(sort: Asc)])
  @@map("pinned_repos")
}
